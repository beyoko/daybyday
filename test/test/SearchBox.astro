---
const search = async (query) => {
  // 在 Markdown 目录下获取所有文件列表
  const allFiles = await Astro.glob('../../pages/posts/*.md')

  // 遍历每个文件
  for (const file of allFiles) {
    // 读取文件内容
    const content = readFile(file)

    // 在文件内容中搜索匹配的内容
    if (content.includes(query)) {
      // 将匹配的文件信息添加到结果列表
      results.push({
        fileName: getFileName(file),
        filePath: file,
        preview: generatePreview(content, query),
      })
    }
  }
}

---

<div class="w-full p-4">
  <input
    type="text"
    placeholder="Search..."
    class="w-full px-4 py-2 text-gray-900 border rounded shadow focus:outline-none focus:ring focus:border-blue-300"
    on:input={(e) => search(e.target.value)}
  />
</div>

