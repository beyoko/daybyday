---
const results = [] // 将搜索结果存储在这里

// 根据搜索结果生成文件预览内容
const renderResults = () => {
  return results.map((result) => (
    `<div class="border p-4 my-2 flex items-center justify-between">
      <div class="flex-1">
        <h2 class="text-lg font-semibold">
          {result.fileName}
        </h2>
        <p class="text-gray-600">
          {result.preview}
        </p>
      </div>
      <a
        href={result.filePath}
        target="_blank"
        class="text-blue-500 hover:underline"
      >
        Open
      </a>
    </div>`
  ))
}
---

<div>
  <h1 class="text-xl font-semibold">Search Results</h1>
  {renderResults()}
</div>

