---
import { Astro, Link } from '@astro/types';

const fetchMarkdownHeadings = async () => {
  const allPosts = await Astro.glob('../pages/posts/*.md')
  const headings = [];

  for (const file of allPosts) {
    const { getHeadings } = await import(file.url);
    headings.push(...await getHeadings());
  }

  return headings;
};

const headings = await fetchMarkdownHeadings();
---

<section>
  <h1>Markdown Headings</h1>
  <ul>
    {headings.map(heading => (
      <li key={heading.slug}>
        <Link href={`#${heading.slug}`}>{heading.text}</Link>
      </li>
    ))}
  </ul>
</section>

