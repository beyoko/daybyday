// SearchEngine.astro

---
export let searchQuery = '';
export let searchResults = [];

function search() {
  const allPosts = getAllPosts(); // 获取所有文章列表
  const keyword = searchQuery.toLowerCase(); // 获取搜索关键字并转换为小写

  searchResults = allPosts.filter((post) => {
    const title = post.title.toLowerCase(); // 获取文章标题并转换为小写
    return title.includes(keyword); // 返回标题中包含关键字的文章
  });
}

function getAllPosts() {
  // 这里是获取所有文章列表的逻辑
  // 你可以根据你的实际情况实现它，例如从数据库或其他数据源获取文章列表
  return [
    { title: '文章标题1', url: '/posts/1' },
    { title: '文章标题2', url: '/posts/2' },
    { title: '文章标题3', url: '/posts/3' },
  ];
}
---

<astroscript>
  function handleSearch(e) {
    searchQuery = e.target.value;
    search();
  }
</astroscript>

<div>
  <input type="text" placeholder="搜索" oninput={handleSearch} />

  {searchResults.length > 0 && (
    <ul className="mt-4">
      {searchResults.map(post => (
        <li key={post.title} className="text-blue-500">
          <a href={post.url}>{post.title}</a>
        </li>
      ))}
    </ul>
  )}
</div>
