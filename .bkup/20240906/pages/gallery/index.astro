---
import { getCollection } from 'astro:content'
import Content from '@/components/Content.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Image from 'astro/components/Image.astro'
import Link from '@/components/Link.astro'
import { siteMeta } from '@/consts'

const allPosts = await getCollection('post')

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif}',
)
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Content>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        allPosts.map((post) => {
          const heroImageAsset = images[post.data.heroImage]
          const heroImageSrc = heroImageAsset
            ? heroImageAsset()
            : post.data.heroImage

          return (
            <li class="relative p-4 text-center rounded-md bg-gray-100 dark:bg-gray-900 opacity-80 hover:opacity-100">
              <Link href={`/project/${post.slug}/`}>
                <Image
                  class="rounded-xl"
                  loading="lazy"
                  src={heroImageSrc}
                  width={720}
                  height={720 / 1.777}
                  alt={post.data.heroImageAlt as string}
                  inferSize
                />
                <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                <div>{post.data.description}</div>
              </Link>
            </li>
          )
        })
      }
    </ul>
  </Content>
</BaseLayout>
