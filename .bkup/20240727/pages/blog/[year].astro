---
import { getCollection } from 'astro:content';
import YearPostsLayout from '@/layouts/YearPostsLayout.astro'

export const getStaticPaths = async () => {
  const allPosts = await getCollection('post');
  
  // 提取年份并去重
  const years = new Set(allPosts.map(post => post.data.pubDate.getFullYear()));

  // 生成路径数组
  return Array.from(years).map(year => ({
    params: { year: year.toString() },
  }));
};

const { year } = Astro.params; // 获取年份参数
---

<YearPostsLayout year={year} />
