---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import Image from '@/components/Image.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import Location from '@/components/Location.astro'
import Link from '@/components/Link.astro'
import FormattedDate from '@/components/FormattedDate.astro'
import { siteMeta } from '@/consts'

interface Props {
  data: {
    title: string
    description: string
    pubDate: Date
    heroImage: {
      src: string
      height: number
      width: number
    }
    heroImageAlt: string
  }
  updatedDate?: Date | undefined
  tags?: string[] | undefined
  category: CollectionEntry<'post'>
  date: string
}

const { category } = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif}',
)
console.log('images:', images)

const posts = (await getCollection('post'))
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
  )
  .filter(
    (item) =>
      Array.isArray(item.data.tags) && item.data.tags.includes(category),
  )
---

<BaseLayout
  title={category + ` / ${siteMeta.title}`}
  description={siteMeta.description}
>
  <Content>
    <Location>{category}</Location>
    <section>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          posts.map((post) => (
            <li class="relative text-center bg-white dark:bg-black border-2 border-black dark:border-white rounded-xl">
              <Image
                className="rounded-lg object-cover object-center aspect-square"
                loading="lazy"
                src={post.data.heroImage}
                width={720}
                height={720 / 1.777}
                alt={post.data.heroImageAlt}
                inferSize
              />
              <div class="absolute bottom-0 p-4 bg-black/50 text-zinc-50 hover:text-zinc-white rounded-b-xl w-full">
                <Link href={`/post/${post.slug}/`}>
                  <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                </Link>
                <div>{post.data.description}</div>
                <p>
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </Content>
</BaseLayout>
