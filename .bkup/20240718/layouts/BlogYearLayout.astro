---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import { siteMeta } from '@/consts'

// 获取当前年份
const { year } = Astro.params
const allPosts = (await getCollection('post')).sort(
  (a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
)

// 筛选出当前年份的文章
const postsOfYear = allPosts.filter(
  (post) => new Date(post.data.pubDate).getFullYear() == year,
)

// 分页展示，每次展示12个
const pageSize = 12
let currentPage = 1
const postsToShow = postsOfYear.slice(0, currentPage * pageSize)
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Content>
    <section>
      <div class="container mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Posts from {year}</h1>
        <div class="space-y-6">
          <ul class="space-y-2">
            {
              postsToShow.map((post) => (
                <li key={post.data.title} class="text-lg leading-relaxed">
                  {post.data.title}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>
  </Content>
</BaseLayout>
