---
import type { MarkdownHeading } from 'astro'
import { getCollection } from 'astro:content'
import '@/styles/prism.css'
import ThemeToggleButton from '@/lib/ThemeToggleButton'
import DropdownMenu from '@/lib/DropdownMenu'
import Link from '@/components/Link.astro'

export interface Props {
  content: {
    title: string
  }
  headings: MarkdownHeading[]
  description: string
  tags: string[]
}

const { description, tags = [] } = Astro.props

const allPosts = await getCollection('post')
const allTags = new Set<string>()
allPosts.map((post) => {
  post.data.tags && post.data.tags.map((tag: string) => allTags.add(tag))
})

console.log('Astro.props:', Astro.props)
console.log('tags:', tags)
---

<header class="sticky w-full p-2 z-20">
  <div class="mx-auto max-w-5xl">
    <nav class="flex items-center text-base gap-3">
      <Link href="/" data-astro-prefetch="false" className="group ">
        <h2
          class="p-2 font-semibold antialiased tracking-tighter"
          title="@JoYo"
        >
          JoYo
        </h2>
      </Link>

      <div class="flex-1"></div>

      <div>
        <Link href="/blog">Blog</Link>
      </div>
      <div class="hidden md:block">
        <Link href="/categories">Categories</Link>
      </div>
      <div class="block md:hidden linkColor" title="Category">
        <DropdownMenu client:visible tags={Array.from(allTags)} />
      </div>
      <div class="linkColor" title="Theme">
        <ThemeToggleButton client:visible />
      </div>
    </nav>
  </div>
</header>
