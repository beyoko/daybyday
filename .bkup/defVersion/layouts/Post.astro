---
import GlobalHead from '../components/GlobalHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import BackHome from '../components/BackHome.astro';
import Prose from '../components/Prose.astro';
import { SITE_TITLE } from '../consts'

export interface Props {
  content: {
    title: string
    description: string
    pubDate: string
    createdAt?: string
    updatedAt?: string
    heroImage?: string
    tags: string[]
    draft?: boolean
  }
}

const {
  content: { title, description, heroImage, pubDate, draft, tags }
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <GlobalHead title={title + ` / ${SITE_TITLE}`} description={description} heroImage='fish.png' />
  </head>

  <Body>
    <Header />
    <main class="pt-[56px]">
      <Content className="pt-6">
        <div class="mb-8">
          {
            heroImage && (
              <img
                class="border border-slate-300 dark:border-zinc-700 rounded-xl"
                width={720}
                height={360}
                src={heroImage}
                alt=""
              />
            )
          }
        </div>
        <div class="mb-8">
          draft &&
            <p class="">draft</p>
            tags &&
            <div class="">
            {
              tags.map((tab: string) => {
                { <a href='./categoryposts/tab/${tag.toLocaleLowerCase() }'></a>}
              })
            }
            </div>
        </div>
        <h1>{pubDate}</h1>
        <h1 class="text-3xl my-1">{title}</h1>
        <div>{description}</div>
        <hr class="border-top border-zinc-400 my-4" />
        <Prose>
          <slot />
        </Prose>
        <hr class="border-top border-zinc-400 my-4" />
        <BackHome />
      </Content>
    </main>
    <Footer />
  </Body>
</html>

