---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import { allPosts } from '@/lib/post'
import CategoryLayout from '@/layouts/CategoryLayout.astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const allTags: Set<string> = new Set<string>()

  allPosts.map((post) => {
    post.data.tags && post.data.tags.map((tag: string) => allTags.add(tag))
  })

  return Array.from(allTags).map((tag: string) => {
    params: {
      tag: tag.toLowerCase(),
    },
      props: {
        tagName: tag,
      },
  })
}

const { tagName }: { tag: string } = Astro.props
---

<CategoryLayout category={tagName} />
