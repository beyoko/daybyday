---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Location from '@/components/Location.astro'
import Content from '@/components/Content.astro'
import BlogLink from '@/lib/BlogLink'
import PostYear from '@/lib/PostYear'
import { siteMeta } from '@/consts'
import '@/styles/prism.css'

interface Props {
  data: {
    title: string
    description: string
    pubDate: Date
    heroImage: {
      src: string
      height: number
      width: number
    }
    heroImageAlt: string
  }
  updatedDate?: Date | undefined
  tags?: string[] | undefined
  category: CollectionEntry<'post'>
  date: string
}

const { category } = Astro.props

const allPosts = await getCollection('post')

const categoryPosts = allPosts
  .filter(
    (item) =>
      Array.isArray(item.data.tags) && item.data.tags.includes(category),
  )
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))

const postsByYear = categoryPosts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear()
  acc[year] = acc[year] || []
  if (acc[year].length < 6) acc[year].push(post)
  return acc
}, {})

const sortedYears = Object.keys(postsByYear).sort((a, b) => b - a)
---

<BaseLayout
  title={category + ` / ${siteMeta.title}`}
  description={siteMeta.description}
>
  <Content>
    <Location>{category}</Location>
    <section>
      {
        sortedYears.map((year) => (
          <ul class="relative p-6">
            <PostYear postYear={year} />
            <BlogLink posts={postsByYear[year]} />
          </ul>
        ))
      }
    </section>
  </Content>
</BaseLayout>
