---
import type { CollectionEntry } from 'astro:content'

import MarkdownLayout from '@/layouts/Markdown.astro'
import GlobalHead from '../components/GlobalHead.astro'
import Prose from '../components/Prose.astro'
import BackToTop from '../components/BackToTop.astro'

import { siteMeta } from '../consts'

export interface Props {
  content: {
    title: string
    description: string
    pubDate: string
    tags: string[]
    heroImage?: string
  }
}

const {
  content: { title, description, heroImage, pubDate }
} = Astro.props
---

<MarkdownLayout title={title} description={description}>
  <div class="mb-8">
    {
      heroImage && (
        <img
          class="border-2 border-zinc-950 dark:border-white rounded-xl"
          width={720}
          height={360}
          src={heroImage}
          alt=""
        />
      )
    }
  </div>
  <h1>{pubDate}</h1>
  <h1 class="text-3xl my-1 font-mplus">{title}</h1>
  <div>{description}</div>
  <hr class="border-top border-zinc-400 my-4" />
  <Prose>
    <slot />
  </Prose>
  <span
    class="p-1 underline underline-offset-2 hover:text-orange-500 decoration-orange-500 text-2xl list-disc"
  ></span>

  <BackToTop />
</MarkdownLayout>
