---
import { getCollection } from 'astro:content'
import ThemeToggleButton from '@/components/ThemeToggleButton'
import DropdownMenu from '@/components/DropdownMenu'
import Link from '@/components/Link.astro'

const allPosts = await getCollection('post')
const allTags = new Set<string>()
allPosts.map((post) => {
  post.data.tags && post.data.tags.map((tag: string) => allTags.add(tag))
})
const sortedTags = Array.from(allTags).sort((a, b) =>
  a.localeCompare(b, 'en', { sensitivity: 'base' }),
)

export interface Props {
  content: {
    title: string
  }
  headings: {
    slug: string
    text: string
    depth: number
  }[]
}
---

<header class="fixed w-full p-2 z-20">
  <div class="mx-auto max-w-5xl">
    <nav class="flex items-center justify-between gap-3 text-base">
      <Link
        href="/"
        className="group p-4 font-semibold tracking-tighter inline-flex justify-center rounded-md border border-gray-50 dark:border-gray-950 px-2 py-2 text-base text-white dark:text-black shadow-sm bg-black dark:bg-gray-50 hover:border-gray-950 dark:hover:border-gray-100  transition-all"
        data-astro-prefetch="false"
      >
        C.I.C
      </Link>

      <div class="flex gap-4">
        <div class="hidden md:flex">
          <Link
            href="/categories"
            className="inline-flex justify-center rounded-md border border-gray-400 dark:border-gray-700 px-2 py-2 text-sm font-medium shadow-sm bg-white dark:bg-gray-950 md:hover:border-gray-950 dark:md:hover:border-gray-50 md:hover:bg-gray-50 dark:md:hover:bg-gray-950"
          >
            Categories
          </Link>
        </div>
        <div class="md:hidden flex">
          <DropdownMenu client:visible tags={sortedTags} />
        </div>
        <ThemeToggleButton client:visible />
      </div>
    </nav>
  </div>
</header>
