---
import type { GetStaticPaths } from 'astro'
import type { CollectionEntry } from 'astro:content'
import CategoryPosts from '@/layouts/CategoryPosts.astro'

export const getStaticPaths: GetStaticPaths = async (): Promise<CollectionEntry<'posts'>[]> => {
  const allPosts = await Astro.glob('../posts/*.md')
  const allTags: Set<string> = new Set<string>()
  allPosts.map(post => {
    post.frontmatter.tags &&
      post.frontmatter.tags.map((tag: string) => allTags.add(tag))
  })

  return Array.from(allTags).map((tag: string) => {
    return {
      params: {
        id: tag.toLowerCase()
      },
      props: {
        name: tag
      }
    }
  })
}

const { name }: { name: string } = Astro.props
---
<CategoryPosts category={name} />
