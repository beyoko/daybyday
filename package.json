{
  "name": "daybyday",
  "version": "0.0.5",
  "private": true,
  "repository": "git@github.com:beyoko/daybyday.git",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --show-all --port 3010",
    "start": "astro dev",
    "check": "astro check",
    "preview": "astro preview",
    "prepare": "husky install",
    "eslint": "eslint ./src --ext '.ts,.astro' --max-warnings 0",
    "eslint:fix": "eslint ./src --fix --ext '.ts,.astro' --max-warnings 0",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint": "lint-staged --config .lintstagedrc.js"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@astrojs/mdx": "^2.2.2",
    "@astrojs/react": "^3.3.1",
    "@astrojs/rss": "^4.0.5",
    "@astrojs/sitemap": "^3.1.2",
    "@astrojs/tailwind": "^5.1.0",
    "@headlessui/react": "^1.7.19",
    "@heroicons/react": "^2.1.3",
    "astro": "^4.5.12",
    "axios": "^1.6.8",
    "hastscript": "^9.0.0",
    "marked": "^11.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-toc": "^3.0.2",
    "sharp": "^0.32.6",
    "tailwindcss": "^3.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.00",
    "@types/react-dom": "^18.3.00",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^0.26.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.2",
    "prettier-plugin-tailwindcss": "^0.5.10",
    "typescript": "^5.3.3"
  }
}
