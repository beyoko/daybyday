{
  "name": "daybyday",
  "version": "0.0.6",
  "private": true,
  "repository": "git@github.com:beyoko/daybyday.git",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --show-all --port 3010",
    "start": "astro dev",
    "check": "astro check",
    "preview": "astro preview",
    "eslint": "eslint ./src --ext '.ts,.astro' --max-warnings 0",
    "eslint:fix": "eslint ./src --fix --ext '.ts,.astro' --max-warnings 0",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint": "lint-staged --config .lintstagedrc.js"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@astrojs/react": "^4.2.1",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.1.3",
    "@tailwindcss/vite": "^4.0.14",
    "astro": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.14",
    "hastscript": "^9.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/react": "^19.0.11",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.2"
  }
}
