---
import HeaderLink from '@/components/HeaderLink.astro'

type Props = {
  tags: string[]
}

const { tags } = Astro.props
---

<div class="flex items-center gap-4">
  / {
    tags.map((tag): string => (
      <HeaderLink href={`/categories/${tag.toLowerCase()}`}>{tag}</HeaderLink>
    ))
  }
</div>
