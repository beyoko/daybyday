---
import Link from '@/components/Link.astro'
import { allPosts } from '@/lib/utils'

import '@/styles/prism.css'

const { update, limit = true, categoryList, yearLinkLocation } = Astro.props

// 平均阅读速度
const wordsPerMinute = 200

// 阅读时间计算
const readingTime = (word: string): number => {
  const words = word.split(/\s+/).length
  return Math.ceil(words / wordsPerMinute)
}

const postsByYear = allPosts.reduce((acc, post) => {
  const year = new Date(post.data.pubDate).getFullYear() // 提取年份
  // 如果该年份不存在，则初始化为空数组
  if (!acc[year]) acc[year] = []
  // 将文章添加到相应年份的数组中
  acc[year].push(post)

  return acc // 返回累积器
}, {})

const postsToShow = postsByYear[update].sort((a, b) => {
  return b.data.pubDate.getTime() - a.data.pubDate.getTime()
})

const sortedPosts =
  categoryList || (limit ? postsToShow.slice(0, 5) : postsToShow)
---

<ul class="relative p-6">
  <span class="secColor md:absolute md:right-1 md:top-2 stroke-[2px]">
    <Link className="text-6xl md:text-8xl" href={yearLinkLocation}>
      {update}
    </Link>
  </span>

  <div class="flex flex-col">
    {
      sortedPosts.map((post) => (
        <li class="flex flex-col md:flex-row mb-6 mt-2">
          <Link href={`/post/${post.slug}`}>{post.data.title}</Link>
          <div class="secColor flex flex-row mt-2 md:mt-0">
            <span>
              {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                month: 'short',
                day: '2-digit',
              })}
            </span>
            <span> ·{readingTime(post.body)} Min</span>
          </div>
        </li>
      ))
    }
  </div>
  <slot />
</ul>
