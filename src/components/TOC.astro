---
import type { MarkdownHeading } from 'astro'
import Link from '@/components/Link.astro'
import '@/styles/prism.css'

type Props = {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props
---

<!--  <TocMenu client:visible headings={headings} />-->
<aside class="fixed p-4">
  <ul class="border-l overflow-y-auto max-h-96 space-y-4">
    {
      headings.map((heading) => (
        <li class="lineColor flex">
          <Link
            className={`${heading.depth < 3 && 'font-semibold'}  p-1 text-sm `}
            href={`#${heading.slug}`}
          >
            {heading.text}
          </Link>
        </li>
      ))
    }
  </ul>
</aside>
