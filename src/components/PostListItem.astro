---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content'
import FormattedDate from '@/components/FormattedDate.astro'

const posts = (await getCollection('post')).sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
) // time date

// const latestPosts = (await getPosts()).slice(0, 5) // max 5 posts
---


<section>
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {
      posts.map(post => (
        <li class="relative">
          <a href={`/post/${post.slug}/` }>
            <!--
              <img
                class="rounded-xl "
                loading="lazy"
                width={720 * 2}
                src={post.data.heroImage}
                decoding="async"
                alt=""
              />
            -->
            <Image
              class="rounded-xl"
              loading="lazy"
              src={post.data.heroImage}
              aspectRatio={2.0}
              alt={post.data.heroImageAlt}
              inferSize
            />
            <div class="absolute bottom-0 p-4 text-white bg-black bg-opacity-50 w-full rounded-b-xl">
              <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
              <div>{post.data.description}</div>
              <p class="underline underline-offset-2">
                <FormattedDate date={post.data.pubDate} />
              </p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>
