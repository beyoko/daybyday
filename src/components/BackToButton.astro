---
type Props = {
  buttonFunctionId: string
  children: any
}

const { buttonFunctionId = '' } = Astro.props
---

<button
  id={buttonFunctionId}
  class="pl-2
      pr-3
      border-l
      text-gray-500
      hover:text-black
      dark:hover:text-white
      border-gray-300
      hover:border-gray-700
      dark:border-gray-700
      dark:hover:border-gray-300"
>
  <slot />
</button>
