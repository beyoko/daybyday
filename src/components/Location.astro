---
import { getCollection } from 'astro:content'

interface Props {
  pageId: string // 用于唯一标识页面的 ID，例如 slug 或文件名
  collectionName: string // 集合的名称，例如 "posts" 或 "docs"
}

const { pageId, collectionName } = Astro.props

let title = ''

// 异步获取集合数据
const collection = await getCollection(collectionName)

// 查找匹配的页面
const page = collection.find((p) => p.slug === pageId)

if (page) {
  title = page.data.title
}
---

<h1 class="text-3xl font-bold">{title}</h1>
