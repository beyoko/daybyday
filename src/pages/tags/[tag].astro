---
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Container from '@/components/Container.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import { allPosts } from '@/lib/utils/post'
import { allTags } from '@/lib/utils/tag'
import { siteMeta } from '@/consts'

// 类型增强
type TagParam = string
type YearGroup = {
  year: string
  posts: CollectionEntry<'blog'>[]
}

interface StaticPathParams {
  tag: TagParam
}

interface StaticPathProps {
  posts: CollectionEntry<'blog'>[]
  tagName: string
}

export const getStaticPaths = async () =>
  Array.from(allTags).map((tag) => ({
    params: { tag } satisfies StaticPathParams,
    props: {
      tagName: tag,
      posts: allPosts
        .filter(
          (post) =>
            !post.data.draft &&
            post.data.tags?.some((t) => t.toLowerCase() === tag),
        )
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    } satisfies StaticPathProps,
  }))

const { posts, tagName } = Astro.props as StaticPathProps

// 使用Map提升分组性能
const groupedYears = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear().toString()
  acc.set(year, [...(acc.get(year) || []), post])
  return acc
}, new Map<string, CollectionEntry<'blog'>[]>())

// 转换为排序后的数组
const sortedYears: YearGroup[] = Array.from(groupedYears.entries())
  .sort(([a], [b]) => Number(b) - Number(a))
  .map(([year, posts]) => ({ year, posts }))
---

<BaseLayout
  title={`${tagName} - ${siteMeta.title}`}
  description={`${tagName} | ${siteMeta.description}`}
>
  <Header />
  <main class="pt-[56px]">
    <Container>
      {
        sortedYears.map(({ year, posts }) => (
          <>
            <section class="space-y-10 mb-20">
              <div class="border-primary">
                <h2 class="text-4xl md:text-6xl font-bold mb-8">
                  <a href={`/year/${year}`}>{year}</a>
                </h2>
              </div>
              <ul class="grid gap-8 p-2">
                {posts.map((post) => (
                  <ArrowCard entry={post} />
                ))}
              </ul>
            </section>
          </>
        ))
      }
    </Container>
  </main>
</BaseLayout>
