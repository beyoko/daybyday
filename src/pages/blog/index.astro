---
import type { MarkdownHeading } from 'astro'
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import HeaderLink from '@/components/HeaderLink.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import DropdownMenu from '@/lib/DropdownMenu'
import BottomTagsHeader from '@/components/BottomTagsHeader.astro'
import { allPosts, allTags } from '@/lib/utils'
import { siteMeta } from '@/consts'

type Acc = {
  [year: string]: CollectionEntry<'blog'>[]
}

type Props = {
  content: {
    title: string
  }
  headings: MarkdownHeading[]
  description: string
  tags: string[]
  tagName: string
}

const data = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

// 文章按年份分组，展示全部文章
const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.pubDate.getFullYear().toString()
  if (!acc[year]) {
    acc[year] = []
  }
  acc[year].push(post)
  return acc
}, {})

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a))

const sortedTags = Array.from(allTags).sort((a, b) =>
  a.localeCompare(b, 'en', { sensitivity: 'base' }),
)
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Header>
    <div class="flex items-center gap-4">
      <div class="hidden md:block">
        {
          sortedTags.map((tag) => (
            <HeaderLink href={`/categories/${tag.toLowerCase()}`}>
              {tag}
            </HeaderLink>
          ))
        }/
      </div>
    </div>
    <div class="block md:hidden" title="Category">
      <DropdownMenu client:visible tags={Array.from(allTags)} />
    </div>
  </Header>
  <main class="pt-[56px]">
    <Container className="px-5 flex flex-col md:flex-row">
      <div class="md:w-4/6 space-y-4 p-4">
        {
          years.map((year) => (
            <section class="space-y-4 p-4">
              <div class="text-4xl md:text-6xl font-bold whitespace-nowrap">
                {year}
              </div>
              <div>
                <ul class="flex flex-col gap-4">
                  {posts[year].map((post) => (
                    <li>
                      <ArrowCard entry={post} />
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          ))
        }
      </div>
      <div class="md:w-2/6 p-4"></div>
    </Container>
  </main>
</BaseLayout>
