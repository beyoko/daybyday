---
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import { allPosts } from '@/lib/utils/post'
import { siteMeta } from '@/consts'

type YearGroup = {
  year: string
  posts: CollectionEntry<'blog'>[]
}

// 获取并排序文章
const posts = allPosts
  .filter((post) => !post.data.draft) // 过滤掉草稿文章
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()) // 按发布时间降序

// 按年份分组文章
const groupedPosts = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear().toString()
  if (!acc.has(year)) acc.set(year, []) // 初始化年份组
  acc.get(year)?.push(post) // 添加文章到对应年份
  return acc
}, new Map<string, CollectionEntry<'blog'>[]>())

// 转换分组为数组，并按年份降序排序
const sortedYears: YearGroup[] = [...groupedPosts.entries()]
  .sort(([a], [b]) => Number(b) - Number(a))
  .map(([year, posts]) => ({ year, posts }))
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Header />
  <main class="pt-[56px]">
    <Container>
      {sortedYears.map(({ year, posts }) => (
        <section class="space-y-10 mb-20">
          <h2 class="text-4xl font-semibold">{year}</h2>
          <ul class="grid gap-8 p-2">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </section>
      ))}
    </Container>
  </main>
</BaseLayout>

