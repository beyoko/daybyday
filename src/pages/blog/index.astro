---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import TagsArrowCard from '@/components/TagsArrowCard.astro'
import { allPosts } from '@/lib/utils/post'
import { siteMeta } from '@/consts'

// 获取并排序文章
const posts = allPosts
  .filter((post) => !post.data.draft) // 过滤掉草稿文章
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()) // 按发布时间降序
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Header />
  <main class="pt-[56px]">
    <Container>
      <TagsArrowCard />
      <hr class="dashed border-top border-gray-300 dark:border-gray-700 my-4" />
      <section class="space-y-10 mb-20">
        <ul class="grid gap-4 p-2">
          {posts.map((post) => <ArrowCard entry={post} />)}
        </ul>
      </section>
    </Container>
  </main>
</BaseLayout>
