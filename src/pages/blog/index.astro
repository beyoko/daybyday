---
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import TagsArrowCard from '@/components/TagsArrowCard.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import { allPosts } from '@/lib/post'
import { siteMeta } from '@/consts'
import '@/styles/prism.css'

type Acc = {
  [year: string]: CollectionEntry<'blog'>[]
}

const data = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

// 文章按年份分组，展示全部文章
const updateYear = data.reduce((acc: Acc, post) => {
  const year = post.data.pubDate.getFullYear().toString()
  if (!acc[year]) {
    acc[year] = []
  }
  acc[year].push(post)
  return acc
}, {})

const years = Object.keys(updateYear).sort((a, b) => parseInt(b) - parseInt(a))
---

<BaseLayout title={` ${siteMeta.title}`} description={siteMeta.description}>
  <Header />
  <main class="pt-[56px]">
    <Container>
      <div>
        <TagsArrowCard />
        <hr class="border-top border-gray-300 dark:border-gray-700 my-4" />
        {
          years.map((year) => (
            <section class="space-y-4">
              <div class="text-4xl md:text-6xl font-bold whitespace-nowrap pt-3">
                {year}
              </div>
              <div>
                <ul class="flex flex-col gap-4">
                  {updateYear[year].map((post) => (
                    <li>
                      <ArrowCard entry={post} />
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          ))
        }
      </div>
    </Container>
  </main>
</BaseLayout>
