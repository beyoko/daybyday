---
import { type CollectionEntry, getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import TOC from '@/components/TOC.astro'
import BackToButton from '@/components/BackToButton.astro'
import MobileMenu from '@/components/MobileMenu.astro'
import Header from '@/components/Header.astro'
import { siteMeta } from '@/consts'
import '@/styles/prism.css'

export const getStaticPaths = async () => {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
    props: { blog: post },
  }))
}

type Props = {
  blog: CollectionEntry<'blog'>
}

const { blog } = Astro.props
const { Content, headings } = await blog.render()

const description =
  blog.data.description || blog.body.slice(0, 30).replace(/\n/g, '')

const toc = headings.filter(
  (heading) =>
    heading.depth <= 3 &&
    !(heading.slug === 'footnote-label' && heading.text === 'Footnotes'),
)
---

<BaseLayout title={blog + ` / ${siteMeta.title}`} description={description}>
  <Header>
    <span>/</span>
    <span class="underline font-bold">{blog.data.title}</span>
  </Header>
  <main class="pt-[56px]">
    <Container className="flex markdown-body">
      <div class="md:w-4/6">
        <BackToButton buttonFunId="back-to-prev">Back to blog</BackToButton>
        <hr class="border-top lineColor my-4" />
        <h1 class="flex text-3xl font-roto font-bold my-1 items-center">
          {blog.data.title}
          <div class="block sm:hidden">
            <div class="inline-flex transform ml-2">
              {
                toc.length > 0 && (
                  <MobileMenu typeId="tocMenu" menuTitle="TOC">
                    <TOC headings={headings} />
                  </MobileMenu>
                )
              }
            </div>
          </div>
        </h1>

        <Content />
        <hr class="border-top lineColor my-4" />
        <BackToButton buttonFunId="back-to-top">Back to top</BackToButton>
      </div>

      <div class="md:w-2/6">
        <div class="hidden sm:block">
          <aside class="fixed overflow-y-auto max-h-96">
            {toc.length > 0 && <TOC headings={headings} />}
          </aside>
        </div>
      </div>
    </Container>
  </main>
</BaseLayout>

<style is:global>
  main article.markdown-body {
    ul {
      @apply list-disc list-inside pl-4 mb-4;
    }
    h1,
    h2,
    h3,
    h4,
    h5 {
      @apply font-bold font-roto text-gray-800 dark:text-gray-300 mb-6;
    }
    h1 {
      @apply text-3xl;
    }
    h2 {
      @apply text-2xl;
    }
    h3 {
      @apply text-xl;
    }
    h4 {
      @apply text-lg;
    }
    img {
      @apply border border-gray-300 dark:border-gray-700 rounded-xl mb-6;
    }
    p {
      @apply text-gray-700 dark:text-gray-300 mb-6;
    }
    a {
      @apply underline underline-offset-2 text-black dark:text-white font-semibold decoration-gray-300 dark:decoration-gray-700 hover:decoration-black hover:dark:decoration-white transition-all;
    }
    code {
      font-family: source-code-pro, Menlo, Monaco, Consolas, 'Courier New',
        monospace;
    }
    .astro-code {
      @apply p-3 border-2 border-gray-500 rounded-xl mb-6;
    }
  }
</style>
