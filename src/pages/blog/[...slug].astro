---
import { type CollectionEntry, getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import TOC from '@/components/TOC.astro'
import BackToTop from '@/lib/BackToTop'
import { siteMeta } from '@/consts'
import '@/styles/prism.css'

export const getStaticPaths = async () => {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
    props: { blog: post },
  }))
}

type Props = {
  blog: CollectionEntry<'blog'>
  category: string
}

const { blog } = Astro.props
const { Content, headings } = await blog.render()
---

<BaseLayout
  title={blog + ` / ${siteMeta.title}`}
  description={blog.data.description}
>
  <Header />
  <main class="pt-[56px]">
    <style is:global>
      main article.markdown-body {
        ul {
          @apply list-disc list-inside pl-4 mb-4;
        }
        h1,
        h2,
        h3,
        h4,
        h5 {
          @apply font-bold font-roto text-gray-800 dark:text-gray-300 mb-6;
        }
        h1 {
          @apply text-3xl;
        }
        h2 {
          @apply text-2xl;
        }
        h3 {
          @apply text-xl;
        }
        h4 {
          @apply text-lg;
        }
        img {
          @apply border border-gray-300 dark:border-gray-700 rounded-xl mb-6;
        }
        p {
          @apply text-gray-700 dark:text-gray-300 mb-6;
        }
        a {
          @apply underline underline-offset-2 text-black dark:text-white font-semibold decoration-gray-300 dark:decoration-gray-700 hover:decoration-black hover:dark:decoration-white transition-all;
        }
        code {
          font-family: source-code-pro, Menlo, Monaco, Consolas, 'Courier New',
            monospace;
        }
        .astro-code {
          @apply p-3 border-2 border-gray-500 rounded-xl mb-6;
        }
      }
    </style>

    <Container className="px-5 flex flex-col md:flex-row">
      <div class="md:w-4/6 space-y-4 p-4">
        <article class="markdown-body">
          <h1 class="text-3xl font-roto font-bold my-1">
            {blog.data.title}
          </h1>
          <hr class="border-top border-gray-300 my-4" />
          <Content />
        </article>
      </div>
      <div class="md:w-2/6 p-4">
        <TOC headings={headings}>
          <BackToTop />
        </TOC>
      </div>
    </Container>
  </main>
</BaseLayout>
