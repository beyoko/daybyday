---
import { getCollection } from 'astro:content'
import YearPostMoreLayout from '@/layouts/YearPostMoreLayout.astro'
import { allPosts } from '@/lib/post'

export const getStaticPaths = async () => {

  // 提取年份并去重
  const allYears = new Set(allPosts.map((post) => post.data.pubDate.getFullYear()))

  // 生成路径数组
  return Array.from(allYears).map((year) => ({
    params: { 
      year: year.toString() 
    },
    props: {
      year: year,
    }
  }))
}

const { year } = Astro.props // 获取年份参数
---

<YearPostMoreLayout year={year} />
