---
import Header from '../components/Header.astro';
import Body from '../components/Body.astro';
import Content from '../components/Content.astro';
import Footer from '../components/Footer.astro';
import GlobalHead from '../components/globalHead.astro';
import {SITE_TITLE, SITE_DESCRIPTION} from '../consts';
import BackHome from '../components/BackHome.astro';

const tipsMd = (await Astro.glob('./post/tips/*.md')).sort(
  (a: any, b: any) =>
    new Date(b.frontmatter.pubDate).valueOf() -
    new Date(a.frontmatter.pubDate).valueOf()
)
---

<!DOCTYPE html>
<html lang="en">
<head>
  <GlobalHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<Body>

  <Header title={SITE_TITLE} />
    <Content>
      <section class="flex items-center justify-between px-4 py-3">
      <main class="pt-[56px]">
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            tipsMd.map(postTips =>
              <li class="mb-4">
                <a class="
                  text-gray-800
                  hover:text-white
                  hover:bg-gray-600
                  px-3
                  py-2
                  rounded-md
                  text-sm
                  font-medium
                  link-with-bg
                  "
                  href={postTips.url}
                >
                  <div class="mt-3 text-xl font-bold">
                    {postTips.frontmatter.title}
                  </div>
                  {postTips.frontmatter.description && (
                    <div class="flex">
                      {postTips.frontmatter.description}
                    </div>
                    <div class="py-3 text-center">
                      {postTips.frontmatter.pubDate}
                    </div>
                  )}
                </a>
              </li>
            )
          }
        </ul>
      </main>
      </section>
    </Content>
  <BackHome />
  <Footer />
</Body>
</html>

<style>
.link-with-bg {
  position: relative;
  display: inline-block;
  padding: 0.5rem;
  font-weight: bold;
  color: #fff;
  text-decoration: none;
  transition: all 0.3s ease;
}

/* a background */
.link-with-bg: before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  background-color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  z-index: -1;
}

/* a hold */
.link-with-bg:hover::before {
  opacity: 1;
  transform: scale(1.2);
}
.link-with-bg:hover {
  color: #000;
}
</style>
