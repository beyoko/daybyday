---
// 导入内容集合
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import { allPosts } from '@/lib/utils/post'

export async function getStaticPaths() {
  const years = new Set(
    allPosts
      .filter((post) => !post.data.draft)
      .map((post) => post.data.pubDate.getFullYear().toString()),
  )

  return Array.from(years).map((year) => ({
    params: { year },
    props: {
      posts: allPosts
        .filter(
          (post) =>
            !post.data.draft &&
            post.data.pubDate.getFullYear().toString() === year,
        )
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }))
}

interface Props {
  posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
---

<BaseLayout
  title={`Posts from ${Astro.params.year}`}
  description={`All posts from the year ${Astro.params.year}`}
>
  <Header />
  <main class="pt-[56px]">
    <Container>
      <section class="space-y-10 mb-20">
        <div class="border-primary">
          <h2 class="text-4xl md:text-6xl font-bold mb-8">
            {Astro.params.year}
          </h2>
        </div>
        <ul class="grid gap-8 p-2">
          {
            posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>
    </Container>
  </main>
</BaseLayout>
