---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import { formattedDate } from '@/components/FormattedDate'
import { siteMeta } from '@/consts'

const posts = (await getCollection('post')).sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
) // time date

// const latestPosts = (await getPosts()).slice(0, 5) // max 5 posts
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Content>
    <section>
      <p
        class="mb-8 indent-4 p-4 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900"
      >
        As an indie developer, I&apos;ve been spending hours and hours at my
        desk every day. So, I&apos;ve been continuously improving my workspace
        in order to boost my productivity. Whenever I upload new content, people
        ask me what tools I use. So, here is a living snapshot and a place to
        point curious developers to when I get asked. Most of the links are
        amazon affiliate links, so I&apos;ll get filthy rich if you click them
        and buy something.
      </p>
    </section>

    <section>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          posts.map(post => (
            <li class="relative">
              <a
                class="underline hover:underline "
                href={`/post/${post.slug}/`}
              >
                <img
                  class="border-2 border-zinc-950 dark:border-white rounded-xl"
                  loading="lazy"
                  width={720 * 2}
                  src={post.data.heroImage}
                  alt=""
                />
                <div class="absolute bottom-0 p-4 text-white bg-black bg-opacity-70 border-zinc-950 dark:border-white w-full border-2 border-t-0 rounded-b-lg hover:underline">
                  <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                  <div>{post.data.description}</div>
                  <p class="underline underline-offset-2">
                    {formattedDate(post.data.pubDate)}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Content>
</BaseLayout>
