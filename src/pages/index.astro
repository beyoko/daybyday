---
import GlobalHead from '../components/GlobalHead.astro';
import Body from '../components/Body.astro';
import Content from '../components/Content.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

---

<!DOCTYPE html>
<html lang="en">
<head>
  <GlobalHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>

<style>
@keyframes fade {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@media (max-width: 500px) {
  #name {
    font-size: 13vw;
  }

  #info {
    font-size: 5.3vw;
  }
}
</style>

<Body>
  <Content>
    <section class="text-5xl text-center">
      <div class="flex flex-col items-center justify-center h-screen w-auto">
          <a href="/think" class="">Think</a>
      </div>
    </section>
  </Content>
</Body>
</html>

