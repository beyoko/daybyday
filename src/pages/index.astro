---
import { type CollectionEntry, getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import ArrowCard from '@/components/ArrowCard.astro'
import Link from '@/components/Link.astro'
import { allPosts } from '@/lib/utils'
import { siteMeta } from '@/consts'

type Acc = {
  [year: string]: CollectionEntry<'blog'>[]
}

const data = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

// 文章按年份分组，展示全部文章
const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.pubDate.getFullYear().toString()
  if (!acc[year]) {
    acc[year] = []
  }
  acc[year].push(post)
  return acc
}, {})

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a))
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <Content>
    <div class="space-y-10">
      <div class="space-y-4">
        {
          years.map((year) => (
            <section class="space-y-4">
              <Link className="text-4xl md:text-6xl" href={`/section/${year}`}>
                {year}
              </Link>
              <div>
                <ul class="flex flex-col gap-4">
                  {posts[year].slice(0, 5).map((post) => (
                    <li>
                      <ArrowCard entry={post} />
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </Content>
</BaseLayout>
