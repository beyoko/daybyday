---
import {SITE_TITLE, SITE_DESCRIPTION} from '../consts';
import GlobalHead from '../components/globalHead.astro';
import Body from '../components/Body.astro';
import Header from '../components/Header.astro';
import Content from '../components/Content.astro';
import {IoArrowForward, IoChevronForward} from 'react-icons/io5/index';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <GlobalHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<Body>
  <Header title={SITE_TITLE} />
  <Content>
    <section>
      <h1 class="text-3xl text-center font-mono mt-12 mb-8">
        404
      </h1>
      <div class="text-center py-4">
        <a class="inline-flex items-center gap-1 underline underline-offset-2 decoration-orange-500" href="/">Go to Index</a>
      </div>
    </section>
  </Content>



</Body>
</html>
