---
import { SITE_TITLE, SITE_404, SITE_DESCRIPTION } from '../consts';
import GlobalHead from '../components/globalHead.astro';
import Body from '../components/Body.astro';
import Content from '../components/Content.astro';
import BackHome from '../components/BackHome.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <GlobalHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<Body>
  <Content>
  <div class="flex flex-col items-center justify-center h-screen">
    <section>
      <h1 class="text-5xl text-center font-mono mt-12 mb-8">
        404
      </h1>
      <BackHome />
    </section>
  </div>
  </Content>
</Body>
</html>
