---
import GlobalHead from '@/components/GlobalHead.astro'
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import '@/styles/global.css'

type Props = {
  title: string
  description: string
  category?: boolean
  children: any
}

// export const prerender = true
// server side rendering

const { title, description, category } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <GlobalHead title={title} description={description} />
  </head>
  <body
    class="textColor bg-white dark:bg-black break-words leading-6 transition-colors duration-500 selection:bg-[#f2f2f2] dark:selection:bg-[#1E1E1E]"
  >
    <Header category={category} />
    <slot />
    <Footer />
  </body>
</html>
