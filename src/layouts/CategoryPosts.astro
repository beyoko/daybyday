---
import { Image } from '@astrojs/image/components'
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import Location from '@/components/Location.astro'
import { formattedDate } from '@/components/FormattedDate'
import { siteMeta } from '@/consts'

interface Props {
  category: CollectionEntry<'post'>
}

const { category } = Astro.props

const posts = (await getCollection('post')).sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
)
---

<BaseLayout
  title={category + ` / ${siteMeta.title}`}
  description={siteMeta.description}
>
  <Content>
    <Location>{category}</Location>
    <section>
      <ul class="grid grid-cols-1 md:grid-cols-1 gap-4">
        {
          posts.map(post => (
            <li class="relative overflow-hidden">
              <a href={`/post/${post.slug}/`}>
                <Image
                  class="border-2 border-zinc-950 dark:border-white rounded-xl"
                  loading="lazy"
                  width={720 * 2}
                  src={post.data.heroImage}
                  aspectRatio={2.0}
                  alt=""
                />
                <div class="absolute bottom-0 p-4 text-white bg-black bg-opacity-50 bg-no-repeat bg-size-auto border-2 border-t-0 border-zinc-950 dark:border-white w-full rounded-b-lg hover:underline">
                  <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                  <div>{post.data.description}</div>
                  <div class="underline underline-offset-2">
                    {formattedDate(post.data.pubDate)}
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Content>
</BaseLayout>
