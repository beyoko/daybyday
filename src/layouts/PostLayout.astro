---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import { Image } from '@astrojs/image/components'
import { TagIcon } from '@heroicons/react/24/solid'
import MarkdownLayout from '@/layouts/MarkdownLayout.astro'
import TagsLink from '@/components/TagsLink'
import Prose from '@/components/Prose.astro'

import { siteMeta } from '@/consts'

type Props = CollectionEntry<'post'>['data']

const allPosts = await getCollection('post')
const allTags = new Set<string>()

allPosts.map(post => {
  post.data.tags &&
    post.data.tags.map((tag: string) => allTags.add(tag))
})
const sortedTags = Array.from(allTags).sort((a, b) =>
  a.localeCompare(b, 'en', { sensitivity: 'base' })
)

const { title, description, pubDate, heroImage, headings } = Astro.props
---

<MarkdownLayout
  title={title + ` / ${siteMeta.title}`}
  description={description}
  image={heroImage}
>
  <div class="mb-8">
    {
      heroImage && (
        <Image
          class="border-2 border-zinc-950 dark:border-white rounded-xl"
          loading="lazy"
          width={720}
          height={360}
          src={heroImage}
          aspectRatio={2.0}
          alt=""
        />
      )
    }
  </div>
  <h1>
    {pubDate}
  </h1>
  <h1 class="text-3xl my-1 font-mplus">{title}</h1>
  <div>{description}</div>
  <div class="flex items-center space-x-2 text-sm">
    <TagIcon className="h-5 w-5 text-gray-500" />
    <TagsLink tags={sortedTags} includeComma={true} />
  </div>
  <hr class="border-top border-zinc-400 my-4" />
  <Prose>
    <slot />
  </Prose>
  <span
    class="p-1 underline underline-offset-2 hover:text-orange-500 decoration-orange-500 text-2xl list-disc"
  ></span>
</MarkdownLayout>
