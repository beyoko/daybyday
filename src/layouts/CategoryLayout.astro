---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import Image from '@/components/Image.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import Location from '@/components/Location.astro'
import PostListItem from '@/components/PostListItem.astro'
import FormattedDate from '@/components/FormattedDate.astro'
import { siteMeta } from '@/consts'

interface Props {
  category: CollectionEntry<'post'>
}

const { category } = Astro.props

const posts = (await getCollection('post'))
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).valueOf() -
      new Date(a.data.pubDate).valueOf()
  )
  .filter((item) => item.data.tags.includes(category))
---

<BaseLayout
  title={category + ` / ${siteMeta.title}`}
  description={siteMeta.description}
>
  <Content>
    <Location>{category}</Location>
    <section>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          posts.map(post => (
            <li class="relative">
              <a href={`/post/${post.slug}/` }>
                <Image
                  class="rounded-xl"
                  loading="lazy"
                  src={post.data.heroImage}
                  aspectRatio={2.0}
                  alt={post.data.heroImageAlt}
                  inferSize
                />
                <div class="absolute bottom-0 p-4 text-white bg-black bg-opacity-50 w-full rounded-b-xl">
                  <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                  <div>{post.data.description}</div>
                  <p class="underline underline-offset-2">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Content>
</BaseLayout>
