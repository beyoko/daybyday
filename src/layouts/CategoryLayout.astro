---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Location from '@/components/Location.astro'
import Content from '@/components/Content.astro'
import Link from '@/components/Link.astro'
import { siteMeta } from '@/consts'
import '@/styles/prism.css'

interface Props {
  data: {
    title: string
    description: string
    pubDate: Date
    heroImage: {
      src: string
      height: number
      width: number
    }
    heroImageAlt: string
  }
  updatedDate?: Date | undefined
  tags?: string[] | undefined
  category: CollectionEntry<'post'>
  date: string
}

const { category } = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif}',
)
console.log('images:', images)

const posts = (await getCollection('post'))
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
  )
  .filter(
    (item) =>
      Array.isArray(item.data.tags) && item.data.tags.includes(category),
  )
---

<BaseLayout
  title={category + ` / ${siteMeta.title}`}
  description={siteMeta.description}
>
  <Content>
    <Location>{category}</Location>
    <section>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          posts.map((post) => {
            const heroImageAsset = images[post.data.heroImage]
            const heroImageSrc = heroImageAsset
              ? heroImageAsset()
              : post.data.heroImage

            return (
              <li class="relative p-4 text-center rounded-xl bg-gray-100 dark:bg-gray-900 opacity-80 hover:opacity-100">
                <Link href={`/post/${post.slug}/`}>
                  <Image
                    class="rounded-xl"
                    loading="lazy"
                    src={heroImageSrc}
                    width={720}
                    height={720 / 1.777}
                    alt={post.data.heroImageAlt as string}
                    inferSize
                  />
                  <h4 class="mt-3 text-xl font-bold">{post.data.title}</h4>
                  <div>{post.data.description}</div>
                </Link>
              </li>
            )
          })
        }
      </ul>
    </section>
  </Content>
</BaseLayout>
