---
import GlobalHead from '../components/GlobalHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import BackHome from '../components/BackHome.astro';
import Prose from '../components/Prose.astro';
import { SITE_TITLE } from '../consts'

export interface Props {
  content: {
    title: string
    description: string
    pubDate: string
    heroImage?: string
    tags: string[]
  }
}

const {
  content: { title, description, heroImage, pubDate }
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <GlobalHead title={title + ` / ${SITE_TITLE}`} description={description} image='heroImage' />
  </head>

  <Body>
    <Header title={SITE_TITLE} />
      <main class="pt-[70px]">
        <Content className="pt-4 rounded-md bg-gray-50 dark:bg-gray-950">
          <div class="mb-8">
            {
              heroImage && (
                <img
                  class="border border-slate-300 dark:border-zinc-700 rounded-xl"
                  width={720}
                  height={360}
                  src={heroImage}
                  alt=""
                />
              )
            }
          </div>
          <div class="mb-8">
          <h1>{pubDate}</h1>
          <h1 class="text-3xl my-1">{title}</h1>
          <div>{description}</div>
          <hr class="border-top border-zinc-400 my-4" />
          <Prose>
            <slot />
          </Prose>
          <hr class="border-top border-zinc-400 my-4" />
          <BackHome />
        </Content>
      </main>
    <Footer />
  </Body>
</html>

