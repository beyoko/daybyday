---
import GlobalHead from '../components/GlobalHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import Prose from '../components/Prose.astro'
import BackToTop from '../components/BackToTop.astro'
import RightSidebar from '../components/RightSidebar/RightSidebar.astro'
import { SITE_TITLE } from '../consts'
import type { MarkdownLayoutProps } from 'astro'

type Props = MarkdownLayoutProps<{
  content: {
    title: string
    description: string
    pubDate: string
    tags: string[]
    heroImage?: string
  }
}>

const {
  content: { title, description, heroImage, pubDate }
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <GlobalHead
      title={title + ` / ${SITE_TITLE}`}
      description={description}
      image={heroImage}
    />
  </head>

  <Body>
    <Header title={SITE_TITLE} />
    <main class="pt-[90px]">
      <Content
        className="pt-4 border-2 border-gray-800 dark:border-gray-200 rounded-md bg-gray-50 dark:bg-gray-950"
      >
        <div class="mb-8">
          {
            heroImage && (
              <img
                class="border border-slate-300 dark:border-gray-700 rounded-xl"
                width={720}
                height={360}
                src={heroImage}
                alt=""
              />
            )
          }
        </div>
        <div class="py-4">
          <h1>{pubDate}</h1>
          <h1 class="text-3xl my-1">{title}</h1>
          <div>{description}</div>
          <hr class="border-top border-gray-400 my-4" />
          <Prose>
            <slot />
          </Prose>
          <hr class="border-top border-gray-400 my-4" />
        </div>
        <div class="py-4"></div>
      </Content>
    </main>
    <RightSidebar />
    <BackToTop />
  </Body>
  <Footer />
</html>
