---
import type { MarkdownLayoutProps } from 'astro'
import GlobalHead from '../components/GlobalHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import Prose from '../components/Prose.astro'
import BackToTop from '../components/BackToTop.astro'
import { SITE_TITLE } from '../consts'

type Props = MarkdownLayoutProps<{
  content: {
    title: string
    description: string
    pubDate: string
    tags: string[]
    heroImage?: string
  }
}>

const {
  content: { title, description, heroImage, pubDate }
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <GlobalHead
      title={title + ` / ${SITE_TITLE}`}
      description={description}
      image={heroImage}
    />
  </head>

  <Body>
    <Header title={SITE_TITLE} />
    <main class="pt-[90px]">
      <Content className="gap-5">
        <div
          class="p-4 mb-4 bg-zinc-50 dark:bg-zinc-950 border-2 border-zinc-950 dark:border-zinc-50 rounded-md"
        >
          <div class="p-4 mb-4">
            {
              heroImage && (
                <img
                  class="border border-slate-300 dark:border-zinc-700 rounded-xl"
                  width={720}
                  height={360}
                  src={heroImage}
                  alt=""
                />
              )
            }
          </div>
          <div class="py-4">
            <h1>{pubDate}</h1>
            <h1 class="text-3xl my-1">{title}</h1>
            <div>{description}</div>
            <hr class="border-top border-zinc-400 my-4" />
            <Prose onmouseup="showCopyIcon()">
              <slot />
            </Prose>
            <hr class="border-top border-zinc-400 my-4" />
          </div>
          <div class="py-4"></div>
        </div>
      </Content>
    </main>
  </Body>
  <BackToTop />

  <Footer />
</html>
