---
import { type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/Container.astro'
import Header from '@/components/Header.astro'
import BackToButton from '@/components/BackToButton.astro'
import { siteMeta } from '@/consts'
import "@/styles/app.css";

type Props = {
  children: any
  description: string
  blog: CollectionEntry<'blog'>
}

const { blog, description } = Astro.props
---

<BaseLayout title={blog + ` / ${siteMeta.title}`} description={description}>
  <Header>
    <span>/</span>
    <span class="underline font-bold">{blog.data.title}</span>
  </Header>
  <style is:global>
    @reference "@/styles/app.css";
    main article.markdown-body {
      ul {
        @apply list-disc list-inside pl-4 mb-4
      }
      h1,
      h2,
      h3,
      h4,
      h5 {
        @apply font-bold font-roto text-gray-800 dark:text-gray-300 mb-6;
      }
      h1 {
        @apply text-3xl;
      }
      h2 {
        @apply text-2xl;
      }
      h3 {
        @apply text-xl;
      }
      h4 {
        @apply text-lg;
      }
      img {
        @apply border border-gray-300 dark:border-gray-700 rounded-xl mb-6;
      }
      p {
        @apply text-gray-700 dark:text-gray-300 mb-6;
      }
      a {
        @apply underline underline-offset-2 text-black dark:text-white font-semibold decoration-gray-300 dark:decoration-gray-700 hover:decoration-black hover:dark:decoration-white transition-all;
      }
      code {
        font-family: source-code-pro, Menlo, Monaco, Consolas, 'Courier New',
          monospace;
      }
      .astro-code {
        @apply p-3 border-2 border-gray-500 rounded-xl mb-6;
      }
    }
  </style>
  <main class="pt-[56px]">
    <Container className="pt-6 markdown-body">
      <div class="mb-8">
        <slot />
        <hr class="border-top border-gray-300 dark:border-gray-700 my-4" />
        <BackToButton buttonFunctionId="back-to-prev">
          Back to blog
        </BackToButton>
        <BackToButton buttonFunctionId="back-to-top">Back to top</BackToButton>
      </div>
    </Container>
  </main>
</BaseLayout>
