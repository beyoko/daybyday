---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Content from '@/components/Content.astro'
import BackoTopButton from '@/components/BackToTopButtom'
import { siteMeta } from '@/consts'

const { title, description, heroImage, pubDate } = Astro.props
---

<BaseLayout
  title={title + ` / ${siteMeta.title}`}
  description={description}
  heroImage={heroImage}
  pubDate={pubDate}
>
  <Content className="pt-6 bg-white dark:bg-zinc-950 rounded-md">
    <slot />
    <BackoTopButton client:visible />
  </Content>
</BaseLayout>
